<!DOCTYPE html>
<html lang="en">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
  <meta name="theme-color" content="#5a38a3">
  <title>Nileprise HRMS</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>

  <style>
    /* =========================================
       1. GLOBAL VARIABLES & RESET
       ========================================= */
    :root {
      --keka-purple: #5a38a3; --keka-dark: #1b2131; --keka-sidebar-hover: #2c344b;
      --keka-bg: #f5f6f8; --border: #e2e8f0; --text-main: #334155; --text-muted: #64748b;
      --card-bg: #ffffff; --alert-bg: #f0fdfa; --alert-border: #bbf7d0;
      --danger-bg: #fef2f2; --danger-border: #fecaca; --danger-text: #ef4444;
      --success-green: #84cc16; --casual-purple: #a855f7; --sick-yellow: #eab308;
    }
    body, html { margin: 0; padding: 0; font-family: 'Inter', sans-serif; background: var(--keka-bg); color: var(--text-main); height: 100vh; overflow: hidden; }

    /* =========================================
       2. SPA MODULE CONTAINERS
       ========================================= */
    #auth-module { display: flex; height: 100vh; width: 100%; background: #fff; z-index: 9999; animation: fadeIn 0.3s ease; }
    #onboarding-module { display: none; height: 100vh; width: 100%; background: var(--keka-bg); align-items: center; justify-content: center; animation: fadeIn 0.4s ease; overflow-y: auto; padding: 2rem 0;}
    #dashboard-module { display: none; flex-direction: column; height: 100vh; width: 100%; animation: fadeIn 0.4s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

    /* =========================================
       3. AUTHENTICATION MODULE (Login/Signup)
       ========================================= */
    .auth-left { flex: 1; background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80') center/cover no-repeat; position: relative; }
    .auth-left::after { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(0,0,0,0.4)); }
    .auth-right { flex: 1; display: flex; align-items: center; justify-content: center; padding: 2rem; background: #ffffff; overflow-y: auto; }
    .auth-wrapper { width: 100%; max-width: 380px; }
    
    .brand-logo { font-size: 1.8rem; font-weight: 800; color: #1b2131; margin-bottom: 2rem; letter-spacing: -0.5px; text-align: center;}
    .brand-logo span { color: var(--keka-purple); }

    .auth-tabs { display: flex; border-bottom: 2px solid var(--border); margin-bottom: 2rem; }
    .auth-tab { flex: 1; text-align: center; padding-bottom: 0.8rem; font-weight: 600; color: var(--text-muted); cursor: pointer; margin-bottom: -2px; border-bottom: 2px solid transparent; transition: 0.2s; }
    .auth-tab.active { color: var(--keka-purple); border-bottom-color: var(--keka-purple); }
    
    .form-input { width: 100%; padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 4px; font-size: 0.95rem; box-sizing: border-box; margin-bottom: 1rem; outline: none; transition: 0.2s; font-family: 'Inter', sans-serif;}
    .form-input:focus { border-color: var(--keka-purple); box-shadow: 0 0 0 3px rgba(90, 56, 163, 0.1); }
    .btn-primary { width: 100%; padding: 0.85rem; background-color: var(--keka-purple); color: white; border: none; border-radius: 4px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-primary:hover { background-color: #4a2b88; }
    .btn-primary:disabled { opacity: 0.7; cursor: not-allowed; }

    .error-msg { color: var(--danger-text); font-size: 0.85rem; font-weight: 500; margin-top: -0.5rem; margin-bottom: 1rem; display: none; }
    .divider { display: flex; align-items: center; text-align: center; margin: 1.5rem 0; color: #94a3b8; font-size: 0.8rem; }
    .divider::before, .divider::after { content: ''; flex: 1; border-bottom: 1px solid var(--border); }
    .divider::before { margin-right: 1rem; } .divider::after { margin-left: 1rem; }

    .phone-input-group { display: flex; align-items: center; border: 1px solid var(--border); border-radius: 4px; margin-bottom: 1rem; background: white; }
    .phone-input-group:focus-within { border-color: var(--keka-purple); box-shadow: 0 0 0 3px rgba(90, 56, 163, 0.1); }
    .country-code { padding: 0.85rem 1rem; border-right: 1px solid var(--border); color: var(--text-muted); font-size: 0.95rem; background: #fdfdfd; border-radius: 4px 0 0 4px;}
    .phone-input { flex: 1; border: none; padding: 0.85rem 1rem; outline: none; font-size: 0.95rem; background: transparent;}

    /* =========================================
       4. ONBOARDING MODULE (Data Entry)
       ========================================= */
    .onboard-card { background: white; padding: 2.5rem; border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); width: 100%; max-width: 600px; margin: auto; }
    .onboard-title { font-size: 1.5rem; font-weight: 700; color: var(--text-main); margin: 0 0 0.5rem 0; }
    .onboard-subtitle { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem; }

    /* =========================================
       5. DASHBOARD LAYOUT (Nav & Sidebar)
       ========================================= */
    .top-nav { height: 50px; background: var(--keka-purple); display: flex; align-items: center; justify-content: space-between; padding: 0 1.5rem; color: white; flex-shrink: 0; z-index: 100;}
    .nav-actions { display: flex; align-items: center; gap: 1rem; position: relative; }
    .profile-icon { width: 30px; height: 30px; background: #0ea5e9; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: bold; cursor: pointer; border: 2px solid transparent; transition: 0.2s;}
    .profile-icon:hover { border-color: white; }
    
    .profile-dropdown { display: none; position: absolute; top: 45px; right: 0; background: white; border: 1px solid var(--border); border-radius: 6px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); width: 180px; overflow: hidden; z-index: 200; animation: fadeIn 0.2s ease; }
    .profile-dropdown.active { display: block; }
    .dropdown-item { padding: 0.8rem 1rem; font-size: 0.85rem; color: var(--text-main); cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 0.5rem; }
    .dropdown-item:hover { background: #f1f5f9; color: var(--keka-purple); }
    .dropdown-item.logout { color: var(--danger-text); border-top: 1px solid var(--border); }
    .dropdown-item.logout:hover { background: var(--danger-bg); }

    .app-body { display: flex; flex: 1; overflow: hidden; }
    .sidebar { width: 85px; background: var(--keka-dark); display: flex; flex-direction: column; align-items: center; padding-top: 1rem; overflow-y: auto; overflow-x: hidden; flex-shrink: 0;}
    .sidebar::-webkit-scrollbar { width: 4px; }
    .sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }

    .nav-item { display: flex; flex-direction: column; align-items: center; color: #94a3b8; font-size: 0.65rem; padding: 0.7rem 0; width: 100%; cursor: pointer; transition: 0.2s; border-left: 3px solid transparent; text-align: center; }
    .nav-item:hover { background: var(--keka-sidebar-hover); color: white; }
    .nav-item.active { background: var(--keka-sidebar-hover); color: white; border-left: 3px solid var(--keka-purple); }
    .nav-icon { font-size: 1.2rem; margin-bottom: 0.3rem; }

    .main-content { flex: 1; overflow-y: auto; padding: 1.5rem 2rem; position: relative; }
    .view-section { display: none; animation: fadeIn 0.3s ease; }
    .view-section.active { display: block; }

    /* =========================================
       6. DASHBOARD COMPONENTS & VIEWS
       ========================================= */
    .card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 6px; padding: 1.2rem; box-shadow: 0 1px 2px rgba(0,0,0,0.02); margin-bottom: 1.5rem;}
    .card-title { font-size: 1rem; font-weight: 600; margin: 0 0 1rem 0; color: var(--text-main); border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;}
    .page-header { font-size: 1.4rem; font-weight: 600; color: #1e293b; margin-bottom: 20px;}
    .btn { padding: 0.6rem 1.5rem; border: none; border-radius: 4px; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: 0.2s; color: white;}
    .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--keka-purple); }
    .btn-outline:hover { border-color: var(--keka-purple); background: #f8fafc; }

    .alert-banner { padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1rem; font-weight: 500; font-size: 0.85rem; }
    .alert-banner.info { background: var(--alert-bg); border: 1px solid var(--alert-border); color: #0f766e; }
    .alert-banner.warning { background: #fffbf0; border: 1px solid var(--alert-border); color: #92400e; }

    .page-sub-tabs { display: flex; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem; overflow-x: auto; white-space: nowrap; }
    .sub-tab { padding: 0.8rem 1.2rem; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); cursor: pointer; border-bottom: 2px solid transparent; transition: 0.2s; text-transform: uppercase; }
    .sub-tab:hover { color: var(--keka-purple); }
    .sub-tab.active { color: var(--keka-purple); border-bottom-color: var(--keka-purple); }

    /* Home View */
    .home-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 1.5rem; }
    .time-widget-horizontal { display: flex; justify-content: space-between; align-items: center; padding: 2rem; background: linear-gradient(to right, #ffffff, #f8fafc); border: 1px solid var(--border); border-radius: 6px; margin-bottom: 1.5rem;}
    .home-clock { font-size: 3rem; font-weight: 300; color: var(--text-main); margin-bottom: 0.2rem; font-variant-numeric: tabular-nums; letter-spacing: -1px;}
    .leave-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; text-align: center; }
    .leave-box { padding: 1rem; background: #f8fafc; border: 1px solid var(--border); border-radius: 6px; }
    .leave-num { font-size: 1.8rem; font-weight: 600; color: var(--keka-purple); margin-bottom: 0.2rem;}
    .leave-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 600;}

    /* Me View */
    .donut-container { width: 120px; height: 120px; margin: 1.5rem auto; position: relative; }
    .donut-chart { width: 100%; height: 100%; transform: rotate(-90deg); }
    .donut-ring { fill: transparent; stroke: #f1f5f9; stroke-width: 4; }
    .donut-segment { fill: transparent; stroke-width: 4; stroke-linecap: round; transition: stroke-dasharray 0.5s ease; }
    .donut-text-center { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; }
    .donut-val { font-size: 1.2rem; font-weight: 700; color: var(--text-main); }
    
    .timeline-container { margin-top: 1rem; position: relative;}
    .timeline-bar { height: 8px; background: var(--border); border-radius: 4px; position: relative; margin-top: 2.5rem; margin-bottom: 0.5rem;}
    .timeline-fill { position: absolute; left: 10%; width: 40%; height: 100%; background: #10b981; border-radius: 4px; }
    .timeline-marker { position: absolute; top: -20px; font-size: 0.7rem; color: var(--text-muted); font-weight: 600; }
    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; text-align: center; }
    .cal-header { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; font-weight: 600; padding: 0.5rem 0; }
    .cal-day { aspect-ratio: 1; border: 1px solid #f1f5f9; border-radius: 4px; display: flex; align-items: flex-start; justify-content: flex-end; padding: 0.4rem; font-size: 0.8rem; font-weight: 500; position: relative; }
    .cal-day.woff { background: #fafafa; color: #a1a1aa; }
    .cal-day.leave { border-color: #c4b5fd; background: #f3e8ff; }

    .perf-split-layout { display: flex; gap: 0; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; min-height: 350px; }
    .perf-filter-pane { flex: 0 0 250px; background-color: #fafafa; border-right: 1px solid var(--border); padding: 1rem; display: flex; flex-direction: column; gap: 1rem; }
    .perf-main-pane { flex: 1; padding: 2rem; display: flex; align-items: center; justify-content: center; background: white; }

    /* Team View */
    .emp-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem; }
    .emp-card { display: flex; gap: 10px; padding: 10px; border: 1px solid var(--border); border-radius: 4px; cursor: pointer; transition: 0.2s; align-items: center;}
    .emp-card:hover { background: #f8fafc; }

    /* Full Profile View */
    .profile-banner { height: 140px; background: linear-gradient(135deg, #1e3a8a, #5a38a3, #3b82f6); border-radius: 6px 6px 0 0; position: relative; padding: 20px; display: flex; align-items: center; gap: 1.5rem; color: white; }
    .profile-banner-avatar { width: 80px; height: 80px; border-radius: 50%; background: #67e8f9; color: #083344; font-size: 2rem; font-weight: 600; display: flex; align-items: center; justify-content: center; border: 3px solid white; }
    .profile-banner-info h1 { margin: 0 0 5px 0; font-size: 1.5rem; display: flex; align-items: center; gap: 10px; }
    .out-badge { background: #ef4444; color: white; font-size: 0.6rem; padding: 2px 6px; border-radius: 4px; vertical-align: middle; }
    
    .profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem;}
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; font-size: 0.85rem; margin-top: 0.5rem;}
    .detail-item { display: flex; flex-direction: column; gap: 0.2rem; }
    .detail-label { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; font-weight: 600; }

    /* Modal */
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(2px); display: flex; align-items: center; justify-content: center; z-index: 1000; opacity: 0; pointer-events: none; transition: 0.2s; }
    .modal-overlay.active { opacity: 1; pointer-events: auto; }
    .modal-content { background: white; padding: 2rem; border-radius: 8px; text-align: center; width: 90%; max-width: 380px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    .pin-input { font-size: 2rem; text-align: center; letter-spacing: 12px; }

    /* Responsive */
    @media (max-width: 768px) {
      #auth-module { flex-direction: column; } .auth-left { display: none; }
      .app-body { flex-direction: column; }
      .sidebar { width: 100%; height: auto; flex-direction: row; flex-wrap: wrap; justify-content: space-around; padding: 0; border-bottom: 1px solid var(--keka-dark); }
      .nav-item { width: auto; padding: 0.8rem 0.5rem; border-bottom: 3px solid transparent; border-left: none; flex: 1 1 auto; }
      .nav-item span:last-child { display: none; } 
      .nav-item.active { border-bottom: 3px solid var(--keka-purple); border-left: none; }
      .home-grid, .profile-grid { grid-template-columns: 1fr; }
      .time-widget-horizontal { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
      .perf-split-layout { flex-direction: column; min-height: auto; }
      .perf-filter-pane { border-right: none; border-bottom: 1px solid var(--border); }
      .form-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <input type="file" accept="image/*" capture="user" id="native-camera" style="display:none;">

  <div class="modal-overlay" id="action-modal">
    <div class="modal-content">
      <h3 style="margin: 0 0 1.5rem 0; color:var(--keka-purple);" id="action-title">Verify Action</h3>
      <select class="form-input" id="employee-select">
        <option value="" disabled selected>Select Your Name</option>
        <option value="Akhil">Akhil</option>
        <option value="Ajay">Ajay</option>
        <option value="Ramadevi">Narapaka Ramadevi</option>
      </select>
      <input type="password" inputmode="numeric" maxlength="4" class="form-input pin-input" id="pin-entry" placeholder="••••">
      <div style="display:flex; gap:0.5rem;">
        <button class="btn btn-outline" style="flex:1;" onclick="closeModal('action-modal')">Cancel</button>
        <button class="btn" style="background:var(--keka-purple); flex:1;" id="btn-submit-pin">Verify GPS</button>
      </div>
      <div id="pin-error" style="color:#ef4444; font-size:0.85rem; margin-top:1rem; font-weight:600;"></div>
    </div>
  </div>

  <div id="auth-module">
    <div class="auth-left"></div>
    <div class="auth-right">
      <div class="auth-wrapper">
        <div class="brand-logo">NILE<span>PRISE</span></div>

        <div class="auth-tabs">
          <div class="auth-tab active" id="tab-login" onclick="switchAuthMode('login')">Login</div>
          <div class="auth-tab" id="tab-signup" onclick="switchAuthMode('signup')">Sign Up</div>
        </div>

        <div id="auth-login-view">
          <h2 style="margin-top:0; font-size:1.2rem;">Welcome back</h2>
          <form onsubmit="handleLogin(event)">
            <input type="text" class="form-input" id="login-id" placeholder="Email, Username, or Mobile" required>
            <input type="password" class="form-input" id="login-pass" placeholder="Password (or leave blank for OTP)">
            <div class="error-msg" id="login-error">Invalid credentials. Please try again.</div>
            <button type="submit" class="btn-primary">Secure Login</button>
          </form>
        </div>

        <div id="auth-signup-view" style="display:none;">
          <h2 style="margin-top:0; font-size:1.2rem;">Create Employee Account</h2>
          
          <div style="display:flex; gap:1rem; margin-bottom: 1rem;">
            <label style="font-size:0.85rem; font-weight:600; cursor:pointer;"><input type="radio" name="signupMethod" value="email" checked onchange="toggleSignupMethod()"> Use Email</label>
            <label style="font-size:0.85rem; font-weight:600; cursor:pointer;"><input type="radio" name="signupMethod" value="mobile" onchange="toggleSignupMethod()"> Use Mobile + OTP</label>
          </div>

          <form id="signup-email-form" onsubmit="handleSignupEmail(event)">
            <input type="email" class="form-input" id="signup-email" placeholder="Company Email Address" required>
            <input type="password" class="form-input" id="signup-pass1" placeholder="Create Password" required>
            <input type="password" class="form-input" id="signup-pass2" placeholder="Confirm Password" required>
            <div class="error-msg" id="signup-email-error">Passwords do not match.</div>
            <button type="submit" class="btn-primary">Create Account</button>
          </form>

          <form id="signup-mobile-form" style="display:none;" onsubmit="handleSignupMobile(event)">
            <div class="phone-input-group">
              <div class="country-code">🇮🇳 +91</div>
              <input type="tel" class="phone-input" id="signup-mobile" placeholder="10-digit mobile number" pattern="[0-9]{10}" required>
            </div>
            <div class="error-msg" id="signup-mobile-error">Mobile number error.</div>
            <div id="recaptcha-container"></div> <button type="submit" class="btn-primary">Send OTP Verification</button>
          </form>
        </div>

        <div id="auth-otp-view" style="display:none;">
          <h2 style="margin-top:0; font-size:1.2rem;">Verify your device</h2>
          <p style="font-size:0.9rem; color:var(--text-muted); margin-bottom:1.5rem;">We've sent a secure one-time password to your mobile device.</p>
          <form onsubmit="handleOTPVerify(event)">
            <input type="text" class="form-input" id="otp-input" placeholder="Enter 6-digit OTP" style="text-align:center; font-size:1.5rem; letter-spacing:8px;" maxlength="6" required>
            <div class="error-msg" id="otp-error">Incorrect OTP. Please check and try again.</div>
            <button type="submit" class="btn-primary">Verify & Create Account</button>
            <div style="text-align:center; margin-top:1rem; font-size:0.85rem; color:var(--keka-purple); cursor:pointer;" onclick="switchAuthMode('signup')">&larr; Back</div>
          </form>
        </div>

      </div>
    </div>
  </div>


  <div id="onboarding-module">
    <div class="onboard-card">
      <h1 class="onboard-title">Complete Profile Setup</h1>
      <p class="onboard-subtitle">Account created successfully. Please enter the employee details below to initialize the HRMS profile.</p>
      
      <form onsubmit="finishOnboarding(event)">
        <h3 style="font-size:1rem; margin-bottom:1rem; border-bottom:1px solid var(--border); padding-bottom:0.5rem;">Personal Information</h3>
        <div class="form-grid">
          <div><label style="font-size:0.8rem; font-weight:600;">First Name *</label><input type="text" class="form-input" required></div>
          <div><label style="font-size:0.8rem; font-weight:600;">Last Name *</label><input type="text" class="form-input" required></div>
          <div><label style="font-size:0.8rem; font-weight:600;">Date of Birth</label><input type="date" class="form-input"></div>
          <div><label style="font-size:0.8rem; font-weight:600;">Personal Email</label><input type="email" class="form-input"></div>
        </div>

        <h3 style="font-size:1rem; margin-bottom:1rem; border-bottom:1px solid var(--border); padding-bottom:0.5rem;">Organizational Data</h3>
        <div class="form-grid">
          <div>
            <label style="font-size:0.8rem; font-weight:600;">Job Title / Role *</label>
            <select class="form-input" required><option value="">Select Role</option><option>Associate</option><option>Developer</option><option>Manager</option></select>
          </div>
          <div>
            <label style="font-size:0.8rem; font-weight:600;">Department *</label>
            <select class="form-input" required><option value="">Select Dept</option><option>Engineering</option><option>Operations</option><option>HR</option></select>
          </div>
          <div style="grid-column: span 2;">
            <label style="font-size:0.8rem; font-weight:600;">Reporting Manager</label>
            <input type="text" class="form-input" placeholder="Search manager name...">
          </div>
        </div>
        <button type="submit" class="btn-primary" style="margin-top:1rem; font-size:1rem;">Save Profile & Enter Dashboard</button>
      </form>
    </div>
  </div>


  <div id="dashboard-module">
    
    <div class="top-nav">
      <div class="brand">NILE<span style="color:#fde047;">PRISE</span></div>
      <div class="nav-actions">
